---
import { getCollection } from 'astro:content';

const stats = (await getCollection('quickStats')).sort((a, b) => a.data.order - b.data.order);
---

<div class="border-b border-slate-200 bg-white">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-y-6 py-8">
      {
        stats.map((stat) => (
          <div class="flex items-center gap-x-4">
            <div class="fact-icon flex-shrink-0">
              <i class={`fa-solid ${stat.data.icon} text-xl`} />
            </div>
            <div>
              <div class="stat-number text-3xl text-slate-900">{stat.data.value}</div>
              <div class="text-xs font-medium text-slate-500 tracking-wider">{stat.data.label}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
