---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
---

<section id="acquire" class="bg-slate-900 py-16 border-t border-slate-800">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <div
        class="inline-block px-5 py-1.5 rounded-3xl bg-white/10 text-sky-400 text-xs font-bold tracking-[1.5px] mb-4"
      >
        EXCLUSIVE OPPORTUNITY
      </div>
      <h2 class="text-white text-4xl md:text-5xl font-extrabold tracking-tighter">
        Ready to own the #1 domain for Sunport parking?
      </h2>
      <p class="mt-4 text-lg text-slate-300 max-w-md mx-auto">
        Submit your best offer today. All serious inquiries are handled confidentially. Secure escrow
        transactions strongly recommended.
      </p>
    </div>

    <div class="max-w-xl mx-auto text-center">
      <div class="bg-white rounded-3xl shadow-2xl p-8 md:p-9 border border-slate-100">
        <p class="text-xs font-bold tracking-wider text-slate-500 mb-2">ACQUISITION CONTACT</p>
        <a
          href={`mailto:${SITE.email}`}
          class="block text-2xl sm:text-3xl font-display text-slate-900 hover:text-sky-600 transition-colors break-all mb-6"
        >
          {SITE.email}
        </a>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={ACQUISITION_MAILTO}
            class="cta-button flex-1 inline-flex items-center justify-center gap-x-2 h-14 bg-sky-500 hover:bg-sky-600 text-white font-extrabold text-lg rounded-3xl"
          >
            <span>Inquire About Acquisition</span>
            <i class="fa-solid fa-envelope"></i>
          </a>

          <button
            type="button"
            id="copy-email-btn"
            class="flex-1 inline-flex items-center justify-center gap-x-2 h-14 border border-slate-300 hover:bg-slate-50 text-slate-700 font-semibold text-lg rounded-3xl transition-all"
          >
            <span id="copy-btn-text">Copy Contact Email</span>
          </button>
        </div>

        <p class="mt-6 text-[10px] text-slate-500 tracking-wider">
          Your information is kept strictly confidential. We recommend using <span
            class="font-semibold">Escrow.com</span
          > for all transactions.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  function copyEmail() {
    const email = 'sales@desertrich.com';
    navigator.clipboard
      .writeText(email)
      .then(() => {
        const btn = document.getElementById('copy-btn-text');
        if (btn) {
          const original = btn.textContent;
          btn.textContent = 'Copied to clipboard!';
          setTimeout(() => {
            btn.textContent = original;
          }, 2200);
        }
      })
      .catch(() => {
        window.location.href = 'mailto:sales@desertrich.com';
      });
  }
  document.getElementById('copy-email-btn')?.addEventListener('click', copyEmail);
</script>
