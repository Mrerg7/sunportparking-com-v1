---
import { ACQUISITION_MAILTO } from '../config/site';
---

<nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex justify-between items-center h-20">
      <a href="/" class="flex items-center gap-x-3">
        <div class="flex items-center justify-center w-11 h-11 bg-slate-900 rounded-2xl shadow-inner">
          <i class="fa-solid fa-plane text-white text-xl"></i>
        </div>
        <div>
          <span class="font-display text-2xl tracking-tighter">sunportparking</span>
          <span class="font-display text-2xl tracking-tighter text-sky-600">.com</span>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
        <a href="#why-valuable" class="text-slate-600 hover:text-slate-900 transition-colors"
          >Why Valuable</a
        >
        <a href="#market-facts" class="text-slate-600 hover:text-slate-900 transition-colors"
          >Market Facts</a
        >
        <a href="#use-cases" class="text-slate-600 hover:text-slate-900 transition-colors"
          >Use Cases</a
        >
      </div>

      <div class="flex items-center gap-x-3">
        <div
          class="hidden sm:flex items-center gap-x-2 bg-emerald-100 text-emerald-700 px-4 h-9 rounded-3xl text-xs font-bold tracking-wider"
        >
          <i class="fa-solid fa-check-double"></i>
          <span>AVAILABLE NOW</span>
        </div>

        <a
          href="#acquire"
          class="hidden md:inline-flex px-6 py-2.5 bg-slate-900 hover:bg-black text-white text-sm font-semibold rounded-3xl transition-all active:scale-[0.985]"
        >
          Make an Offer
        </a>

        <button
          type="button"
          class="md:hidden w-11 h-11 flex items-center justify-center text-slate-600 hover:text-slate-900"
          id="mobile-menu-btn"
          aria-label="Open menu"
        >
          <i class="fa-solid fa-bars text-xl"></i>
        </button>
      </div>
    </div>
  </div>
</nav>

<div id="mobile-menu" class="hidden fixed inset-0 bg-black/60 z-[90] md:hidden" aria-hidden="true">
  <div class="bg-white w-3/4 max-w-xs h-full p-6 shadow-xl">
    <div class="flex justify-between items-center mb-8">
      <span class="font-display text-xl tracking-tighter">sunportparking.com</span>
      <button
        type="button"
        class="text-3xl text-slate-400 hover:text-slate-700 leading-none"
        id="mobile-menu-close"
        aria-label="Close menu">&times;</button
      >
    </div>
    <div class="flex flex-col text-base font-medium gap-y-1">
      <a href="#why-valuable" class="py-3 px-1 text-slate-700 hover:text-sky-600 border-b"
        >Why Valuable</a
      >
      <a href="#market-facts" class="py-3 px-1 text-slate-700 hover:text-sky-600 border-b"
        >Market Facts</a
      >
      <a href="#use-cases" class="py-3 px-1 text-slate-700 hover:text-sky-600 border-b"
        >Use Cases</a
      >
      <a
        href={ACQUISITION_MAILTO}
        class="mt-4 inline-block bg-sky-500 hover:bg-sky-600 text-white text-center py-3.5 rounded-3xl font-bold"
        >Make an Offer Now</a
      >
    </div>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-menu-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
  }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  menu?.addEventListener('click', (e) => {
    if (e.target === menu) closeMenu();
  });
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setTimeout(closeMenu, 300));
  });
</script>
