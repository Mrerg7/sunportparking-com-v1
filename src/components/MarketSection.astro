---
import { getCollection } from 'astro:content';

const facts = await Promise.all(
  (await getCollection('marketFacts'))
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (fact) => {
      const { Content } = await fact.render();
      return { ...fact.data, Content };
    }),
);
---

<section id="market-facts" class="bg-white border-y border-slate-100 py-16">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid lg:grid-cols-12 gap-x-12 gap-y-10 items-center">
      <div class="lg:col-span-7">
        <div class="uppercase tracking-[2px] text-sky-600 text-xs font-bold mb-3">
          ALBUQUERQUE INTERNATIONAL SUNPORT
        </div>
        <h2 class="section-header tracking-tighter mb-6">
          A major airport with strong, consistent demand
        </h2>

        <div class="space-y-6 text-[15px] text-slate-600 leading-relaxed">
          {
            facts.map((fact) => (
              <div class="flex gap-4">
                <div class="mt-1 text-sky-500 flex-shrink-0">
                  <i class="fa-solid fa-check-circle text-xl" />
                </div>
                <p>
                  {fact.highlight ? (
                    <>
                      <strong class="font-semibold text-slate-900">{fact.highlight}</strong>{' '}
                      <fact.Content />
                    </>
                  ) : (
                    <fact.Content />
                  )}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-5 bg-slate-900 text-white rounded-3xl p-8 lg:p-9 modern-shadow">
        <div class="text-sky-400 text-xs tracking-[1.5px] font-bold mb-4">KEY MARKET INSIGHT</div>

        <div class="text-5xl font-extrabold tracking-tighter leading-none mb-2">5.3M+</div>
        <div class="text-lg font-medium text-white/90 mb-6">
          annual passengers creating recurring demand for parking information and reservations.
        </div>

        <div class="pt-6 border-t border-white/20 text-sm text-white/70 space-y-3">
          <div class="flex justify-between items-center">
            <span>Official parking exists</span>
            <span class="font-mono text-xs bg-white/10 px-2.5 py-px rounded">YES</span>
          </div>
          <div class="flex justify-between items-center">
            <span>Independent options &amp; info sites thrive</span>
            <span class="font-mono text-xs bg-white/10 px-2.5 py-px rounded">HIGH DEMAND</span>
          </div>
          <div class="flex justify-between items-center">
            <span>Exact-match domain value</span>
            <span class="font-mono text-xs bg-emerald-400/90 text-emerald-950 px-2.5 py-px rounded font-bold"
              >RARE</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
