---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ACQUISITION_MAILTO, SITE } from '../config/site';
---

<BaseLayout title={`Page Not Found | ${SITE.name}`} noindex={true}>
  <div class="min-h-screen flex items-center justify-center bg-slate-50 px-6">
    <div class="text-center max-w-md">
      <div
        class="inline-flex items-center justify-center w-16 h-16 bg-slate-900 rounded-2xl mb-6 mx-auto"
      >
        <i class="fa-solid fa-plane text-white text-2xl"></i>
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 mb-3">404</h1>
      <p class="text-slate-600 mb-8">This page doesn't exist. Return to the domain listing.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center px-6 py-3 bg-slate-900 text-white font-semibold rounded-2xl hover:bg-black transition-colors"
        >
          Back to Home
        </a>
        <a
          href={ACQUISITION_MAILTO}
          class="inline-flex items-center justify-center px-6 py-3 border border-slate-300 text-slate-700 font-semibold rounded-2xl hover:bg-white transition-colors"
        >
          Contact for Acquisition
        </a>
      </div>
    </div>
  </div>
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />
</BaseLayout>
